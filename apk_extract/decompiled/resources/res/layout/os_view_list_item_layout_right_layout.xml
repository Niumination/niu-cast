<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="end|center_vertical"
    android:orientation="horizontal"
    android:id="@+id/lil_title_layout"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:paddingStart="@dimen/os_list_item_right_layout_padding_start"
    android:paddingEnd="0dp">
    <ViewStub
        android:layout_gravity="end|center_vertical"
        android:id="@+id/os_stub_list_view_red_point"
        android:layout="@layout/os_view_list_item_red_point"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"/>
    <ViewStub
        android:id="@+id/lil_stub_describe_layout"
        android:layout="@layout/os_view_list_item_layout_right_describe_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ViewStub
            android:id="@+id/lil_stub_right_divide_line"
            android:layout="@layout/os_view_list_item_layout_right_divide_line"
            android:layout_width="0.7dp"
            android:layout_height="16dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="16dp"/>
        <com.transsion.widgetslib.widget.OSIconTextView
            android:id="@+id/lil_right_image"
            android:visibility="gone"
            android:layout_width="@dimen/os_dimen_icon_common_size"
            android:layout_height="@dimen/os_dimen_icon_common_size"/>
    </LinearLayout>
    <ViewStub
        android:id="@+id/lil_stub_right_radio"
        android:layout="@layout/os_view_list_item_layout_right_radio"
        android:layout_width="@dimen/os_checked_box_small_wh"
        android:layout_height="@dimen/os_checked_box_small_wh"/>
    <ViewStub
        android:id="@+id/lil_stub_right_switch"
        android:layout="@layout/os_view_list_item_layout_right_switch"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/os_list_item_right_switch_height"/>
    <ViewStub
        android:id="@+id/lil_stub_right_button"
        android:layout="@layout/os_view_list_item_layout_right_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ViewStub
        android:id="@+id/lil_stub_pop_menu"
        android:layout="@layout/os_popup_window_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>
