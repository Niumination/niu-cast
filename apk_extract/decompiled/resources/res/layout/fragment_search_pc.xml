<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/module_pc_search_container"
    android:tag="layout/fragment_search_pc_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.tencent.qgame.animplayer.AnimView
        android:id="@+id/av_search_player"
        android:tag="binding_1"
        android:layout_width="360dp"
        android:layout_height="268dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:scrollbarStyle="outsideOverlay"
        android:textSize="14sp"
        android:textColor="@color/module_pc_search_hint"
        android:ellipsize="end"
        android:id="@+id/tv_pc_tips"
        android:tag="binding_2"
        android:scrollbars="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="7"
        android:fadeScrollbars="false"
        android:overScrollMode="always"
        android:textDirection="anyRtl"
        android:textAlignment="viewStart"
        android:paddingEnd="4dp"
        android:breakStrategy="simple"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.github.rubensousa.gravitysnaphelper.GravitySnapRecyclerView
        android:id="@+id/rcv_pc_devices"
        android:tag="binding_3"
        android:background="@android:color/transparent"
        android:visibility="invisible"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:minHeight="160dp"
        android:paddingHorizontal="15dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_pc_tips"
        app:snapEnabled="true"
        app:snapGravity="center"
        app:snapLastItem="false"
        app:snapMaxFlingSizeFraction="-1"
        app:snapScrollMsPerInch="100"/>
    <com.airbnb.lottie.LottieAnimationView
        android:layout_gravity="center"
        android:id="@+id/iv_pc_lottie"
        android:tag="binding_4"
        android:layout_width="300dp"
        android:layout_height="100dp"
        android:layout_marginTop="70dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_pc_tips"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/module_pc_primary_hit"
        android:textColorLink="@color/os_platform_clickable_color"
        android:gravity="center_horizontal"
        android:id="@+id/tv_pc_bottom"
        android:tag="binding_5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="43dp"
        android:layout_marginBottom="55dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rcv_pc_devices"/>
</androidx.constraintlayout.widget.ConstraintLayout>
