<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/module_pc_search_container"
    android:tag="layout/fragment_wait_accept_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_pc_item"
        android:tag="binding_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/iv_pc_shadow"
            android:layout_width="@dimen/module_pc_shadow_width"
            android:layout_height="@dimen/module_pc_shadow_height"
            android:src="@drawable/module_pc_item_shadow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/iv_pc_item"
            app:layout_constraintStart_toStartOf="@+id/iv_pc_item"/>
        <ImageView
            android:id="@+id/iv_pc_item"
            android:layout_width="@dimen/connecting_pc_item_width"
            android:layout_height="@dimen/connecting_pc_item_height"
            android:layout_marginBottom="10dp"
            android:src="@drawable/module_pc_item_tecno"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/module_pc_wait_connect_hit"
        android:gravity="center"
        android:id="@+id/tv_pc_bottom"
        android:tag="binding_2"
        android:background="@color/module_pc_search_bg_downloadLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="@string/pc_module_pc_client_accept"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_pc_item"/>
    <Button
        android:textSize="16sp"
        android:textColor="@color/text_button_color"
        android:gravity="center"
        android:tag="binding_3"
        android:background="@color/transparent"
        android:padding="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="@string/pc_module_botton_cancel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_pc_bottom"
        style="@style/text_roboto_style_medium"/>
</androidx.constraintlayout.widget.ConstraintLayout>
