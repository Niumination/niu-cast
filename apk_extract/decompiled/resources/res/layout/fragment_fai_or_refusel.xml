<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/module_pc_search_container"
    android:tag="layout/fragment_fai_or_refusel_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/iv_connect_fail"
        android:layout_width="360dp"
        android:layout_height="180dp"
        android:layout_marginTop="57dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/module_pc_connect_fail_hint"
        android:gravity="center"
        android:id="@+id/tv_connect_fail_desc"
        android:tag="binding_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="@dimen/connect_fail_qr_code_padding_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_connect_fail"
        style="@style/text_roboto_style_regular2"/>
    <Button
        android:textSize="14sp"
        android:id="@+id/btn_qr_scan"
        android:tag="binding_2"
        android:layout_width="@dimen/module_pc_one_research_btn_width"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="@string/connect_fail_qr_scan"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_connect_fail_desc"
        style="@style/OS.Widget.Button.Contained.Big.Single"/>
    <Button
        android:textSize="16sp"
        android:textColor="@color/text_button_color"
        android:id="@+id/tv_research"
        android:tag="binding_3"
        android:background="@color/transparent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:text="@string/pc_module_research"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_qr_scan"/>
</androidx.constraintlayout.widget.ConstraintLayout>
