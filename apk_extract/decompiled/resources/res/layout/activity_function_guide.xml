<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/activity_function_guide_0"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.transsion.iotservice.multiscreen.pc.ui.guide.CustomNestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="130dp">
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/function_page"
            android:tag="binding_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </com.transsion.iotservice.multiscreen.pc.ui.guide.CustomNestedScrollView>
    <com.transsion.widgetslib.view.indicator.PageIndicatorWrapper
        android:id="@+id/indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@+id/scroll_view"/>
    <com.transsion.widgetsliquid.view.OSLiquidBigButton
        android:textSize="14sp"
        android:id="@+id/btn_skip"
        android:tag="binding_2"
        android:layout_width="216dp"
        android:layout_height="36dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/indicator"
        app:os_liquid_mixlevel="mix_l6"
        style="@style/OS.Widget.BigButton.Primary.SingleLine"/>
</androidx.constraintlayout.widget.ConstraintLayout>
