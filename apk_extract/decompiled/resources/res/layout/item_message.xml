<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="start"
        android:orientation="vertical"
        android:id="@+id/containerLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true">
        <FrameLayout
            android:id="@+id/bubbleLeftContainer"
            android:background="@drawable/bubble_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14dp"
                android:textStyle="normal"
                android:textColor="@color/bubble_text_color"
                android:gravity="center_vertical"
                android:id="@+id/tvBubbleLeft"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/bubble_max_width"
                android:minHeight="39dp"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:letterSpacing="0"/>
        </FrameLayout>
        <TextView
            android:textSize="10dp"
            android:textColor="#888888"
            android:id="@+id/tvTimeLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:includeFontPadding="false"
            android:layout_marginStart="2dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="end"
        android:orientation="vertical"
        android:id="@+id/containerRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true">
        <FrameLayout
            android:id="@+id/bubbleRightContainer"
            android:background="@drawable/bubble_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14dp"
                android:textStyle="normal"
                android:textColor="@color/bubble_text_color"
                android:gravity="center_vertical"
                android:id="@+id/tvBubbleRight"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/bubble_max_width"
                android:minHeight="39dp"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:letterSpacing="0"/>
        </FrameLayout>
        <TextView
            android:textSize="10dp"
            android:textColor="#888888"
            android:gravity="end"
            android:id="@+id/tvTimeRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:includeFontPadding="false"
            android:layout_marginEnd="2dp"/>
    </LinearLayout>
</RelativeLayout>
