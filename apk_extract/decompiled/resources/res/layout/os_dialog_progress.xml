<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_intro"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/os_space300"
        android:layout_marginEnd="@dimen/os_space300">
        <TextView
            android:textSize="@dimen/os_fontsize_h3"
            android:textColor="@color/os_text_primary2_color"
            android:ellipsize="end"
            android:gravity="start|center_vertical"
            android:id="@+id/text_progress_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/os_progress_dialog_message_min_line_height"
            android:singleLine="true"
            android:layout_weight="1"
            android:textDirection="locale"/>
        <TextView
            android:textSize="@dimen/os_fontsize_h3"
            android:textColor="?attr/os_text_info"
            android:layout_gravity="center"
            android:id="@+id/dialog_progress_tv"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/dialog_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/os_progress_height"
        android:layout_marginTop="@dimen/os_space150"
        android:layout_marginBottom="@dimen/os_space150"
        android:max="100"
        android:paddingStart="@dimen/os_dialog_progress_padding"
        android:paddingEnd="@dimen/os_dialog_progress_padding"
        style="@style/OsProgressBarHorizontalStyle"/>
</LinearLayout>
