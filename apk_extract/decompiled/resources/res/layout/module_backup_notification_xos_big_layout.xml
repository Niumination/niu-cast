<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="14sp"
        android:textColor="@color/notify_title_color"
        android:id="@+id/backup_notification_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ProgressBar
        android:id="@+id/backup_notification_pBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="@dimen/backup_notify_progressbar_margin_top"
        android:progressDrawable="@drawable/progressbar_xos"
        style="@android:style/Widget.ProgressBar.Horizontal"/>
    <TextView
        android:textSize="@dimen/notify_progressnumber_textsize"
        android:textColor="@color/notify_backup_percent_color"
        android:id="@+id/backup_progress_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/backup_notify_progressnumber_margin_top"
        android:layout_marginBottom="@dimen/backup_notify_progressnumber_margin_Bottom"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textSize="13sp"
        android:textStyle="normal"
        android:textColor="@color/xos_cancel_color"
        android:id="@+id/backup_notification_close"
        android:paddingTop="@dimen/backup_notify_progress_close_btn_margin_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pc_module_botton_cancel"/>
</LinearLayout>
