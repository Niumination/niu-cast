<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="@color/os_dialog_divider_color">
    <item>
        <inset>
            <layer-list>
                <item android:top="1px">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/os_dialog_background_color"/>
                    </shape>
                </item>
                <item
                    android:gravity="top"
                    android:height="1px">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/os_dialog_divider_color"/>
                    </shape>
                </item>
            </layer-list>
        </inset>
    </item>
</ripple>
