<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="@color/os_btn_ripple_color">
    <item>
        <layer-list>
            <item
                android:top="1px"
                android:right="1px"
                android:bottom="1px">
                <shape android:shape="rectangle">
                    <solid android:color="@color/os_btn_solid_light"/>
                </shape>
            </item>
            <item android:gravity="top">
                <shape android:shape="rectangle">
                    <solid android:color="@color/os_btn_stroke_light"/>
                    <size android:height="1px"/>
                </shape>
            </item>
            <item android:gravity="right">
                <shape android:shape="rectangle">
                    <solid android:color="@color/os_btn_stroke_light"/>
                    <size android:width="1px"/>
                </shape>
            </item>
            <item android:gravity="bottom">
                <shape android:shape="rectangle">
                    <solid android:color="@color/os_btn_stroke_light"/>
                    <size android:height="1px"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
