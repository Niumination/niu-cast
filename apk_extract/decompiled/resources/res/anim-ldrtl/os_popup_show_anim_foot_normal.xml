<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android" android:shareInterpolator="false">
    <alpha
        android:interpolator="@anim/os_interpolator_popup_show"
        android:duration="250"
        android:fromAlpha="0"
        android:toAlpha="1"/>
    <set
        android:shareInterpolator="false"
        android:ordering="sequentially">
        <scale
            android:interpolator="@anim/os_interpolator_popup_show"
            android:duration="250"
            android:pivotX="100%"
            android:pivotY="100%"
            android:fromXScale="0.3"
            android:toXScale="1.015"
            android:fromYScale="0.3"
            android:toYScale="1.015"/>
        <scale
            android:interpolator="@anim/os_interpolator_dialog_enter_translate_bounce"
            android:duration="250"
            android:pivotX="100%"
            android:pivotY="100%"
            android:startOffset="250"
            android:fromXScale="1.015"
            android:toXScale="0.985"
            android:fromYScale="1.015"
            android:toYScale="0.985"/>
    </set>
</set>
