<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/os_press_primary_bg"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:paddingStart="8dp"
    android:paddingEnd="16dp">
    <ImageView
        android:id="@+id/os_list_popup_selected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/os_list_popup_item_selected2"
        android:layout_marginEnd="8dp"/>
    <TextView
        android:textSize="@dimen/os_popup_menu_size"
        android:textColor="@color/os_popup_menu_text_color"
        android:ellipsize="end"
        android:id="@android:id/text1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
