<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/os_et_second_root_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="?attr/os_et_left_right_padding"
        android:paddingEnd="?attr/os_et_left_right_padding">
        <TextView
            android:textSize="@dimen/os_body_font"
            android:textColor="@color/os_text_secondary_color"
            android:id="@+id/os_et_edit_text_label"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/os_et_edit_text_root"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.transsion.widgetslib.widget.editext.ExtendedEditText
                    android:id="@+id/oet_edit_text"
                    android:background="@null"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:inputType="text"
                    android:textDirection="locale"
                    style="@style/OsEditTextStyle"/>
                <View
                    android:id="@+id/os_et_underline_view"
                    android:background="@color/os_gray_secondary_color"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/os_et_edit_text_right_layout"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true">
                <View
                    android:layout_gravity="center_vertical"
                    android:id="@+id/os_et_edit_text_divider"
                    android:background="@color/os_gray_tertiary_color"
                    android:visibility="gone"
                    android:layout_width="0.67dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="16dp"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/os_et_edit_delete_all"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/os_ic_cancel"
                    android:layout_marginStart="10dp"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/os_et_edit_image_button"
                    android:visibility="gone"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="20dp"/>
                <TextView
                    android:textSize="@dimen/os_edit_text_size"
                    android:textColor="@color/os_text_primary_color"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/os_et_edit_text_right_text"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"/>
                <Button
                    android:textSize="@dimen/os_edit_text_size"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/os_et_edit_text_right_text_button"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:layout_marginStart="16dp"
                    style="@style/OS.Widget.Button.Text"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/os_et_edit_text_left_layout"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true">
                <TextView
                    android:textSize="@dimen/os_edit_text_size"
                    android:textColor="@color/os_text_primary_color"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/os_et_edit_text_left_text"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/os_et_left_edit_image_first"
                    android:visibility="gone"
                    android:layout_width="22dp"
                    android:layout_height="22dp"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/os_et_left_edit_image_second"
                    android:visibility="gone"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="16dp"/>
            </LinearLayout>
        </RelativeLayout>
        <TextView
            android:textSize="@dimen/os_caption_font"
            android:textColor="@color/os_red_basic_color"
            android:ellipsize="end"
            android:gravity="start"
            android:id="@+id/os_et_edit_text_error_hint"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"/>
        <TextView
            android:textSize="@dimen/os_subhead_font"
            android:textColor="@color/os_text_tertiary_color"
            android:ellipsize="end"
            android:gravity="end"
            android:id="@+id/os_et_edit_text_help_hint"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="1"/>
    </LinearLayout>
</merge>
