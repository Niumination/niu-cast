<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1">
    <Space
        android:id="@+id/os_foot_opt_space"
        android:layout_width="@dimen/os_foot_bar_item_icon_size"
        android:layout_height="@dimen/os_foot_bar_item_icon_size"
        android:layout_centerInParent="true"/>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/os_fob_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:paddingStart="@dimen/os_foot_bar_item_text_start_end_padding"
        android:paddingEnd="@dimen/os_foot_bar_item_text_start_end_padding">
        <com.transsion.widgetslib.widget.OSMaskImageView
            android:id="@+id/os_foot_opt_bar_item_icon"
            android:layout_width="@dimen/os_foot_bar_item_icon_size"
            android:layout_height="@dimen/os_foot_bar_item_icon_size"/>
        <TextView
            android:textSize="@dimen/os_foot_bar_item_text_size"
            android:ellipsize="end"
            android:id="@+id/os_foot_opt_bar_item_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/os_foot_bar_item_text_paddingTop"
            android:minHeight="@dimen/os_foot_bar_item_text_height"
            android:maxLines="1"
            android:fontFamily="sans-serif"/>
    </LinearLayout>
    <ViewStub
        android:id="@+id/os_stub_fpb_red_point"
        android:layout="@layout/os_foot_opt_bar_item_red_point"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-2dp"
        android:layout_alignTop="@+id/os_foot_opt_space"
        android:layout_marginStart="-2dp"
        android:layout_toEndOf="@+id/os_foot_opt_space"/>
</RelativeLayout>
