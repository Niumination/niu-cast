<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.transsion.widgetslib.widget.timepicker.wheel.WheelView
        android:id="@+id/dayWheel"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:wheelWidth="@dimen/picker_wheel_width_day"/>
    <com.transsion.widgetslib.widget.timepicker.wheel.WheelView
        android:id="@+id/monthWheel"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:wheelWidth="@dimen/picker_wheel_width_month"/>
    <com.transsion.widgetslib.widget.timepicker.wheel.WheelView
        android:id="@+id/yearWheel"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:wheelWidth="@dimen/picker_wheel_width_year"/>
    <com.transsion.widgetslib.widget.timepicker.wheel.WheelView
        android:id="@+id/minWheel"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:wheelWidth="@dimen/picker_wheel_width_minute"/>
    <com.transsion.widgetslib.widget.timepicker.wheel.WheelView
        android:id="@+id/hourWheel"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:wheelWidth="@dimen/picker_wheel_width_hour"/>
    <com.transsion.widgetslib.widget.timepicker.wheel.WheelView
        android:id="@+id/formatWheel"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:wheelWidth="@dimen/picker_wheel_width_format"/>
    <com.transsion.widgetslib.widget.timepicker.wheel.WheelView
        android:id="@+id/monthDayWheel"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:wheelWidth="@dimen/picker_wheel_width_month_day"/>
</LinearLayout>
