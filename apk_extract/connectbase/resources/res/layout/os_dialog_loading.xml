<?xml version="1.0" encoding="utf-8"?>
<com.transsion.widgetslib.view.MaxWidthRelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="180dp">
    <com.transsion.widgetslib.view.LoadingView
        android:id="@+id/osLoading"
        android:layout_width="@dimen/os_loading_default_size"
        android:layout_height="@dimen/os_loading_default_size"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/os_text_tertiary_color"
        android:ellipsize="end"
        android:id="@+id/messageTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="1"
        android:layout_below="@+id/osLoading"
        android:layout_centerHorizontal="true"/>
</com.transsion.widgetslib.view.MaxWidthRelativeLayout>
