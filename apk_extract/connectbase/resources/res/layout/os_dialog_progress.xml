<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_intro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <TextView
            android:textSize="@dimen/os_body_font"
            android:textColor="@color/os_text_primary2_color"
            android:ellipsize="end"
            android:gravity="start|center_vertical"
            android:id="@+id/text_progress_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/os_progress_dialog_message_line_height"
            android:maxLines="1"
            android:layout_weight="1"
            android:textDirection="locale"
            android:lineHeight="@dimen/os_progress_dialog_message_line_height"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/os_text_secondary_color"
            android:layout_gravity="right"
            android:id="@+id/dialog_progress_tv"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/dialog_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/os_progress_height"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="8dp"
        android:max="100"
        android:paddingStart="@dimen/os_dialog_progress_padding"
        android:paddingEnd="@dimen/os_dialog_progress_padding"
        style="@style/OsProgressBarHorizontalStyle"/>
</LinearLayout>
