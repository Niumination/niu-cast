<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:background="?attr/OsBgPrimary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/relative_root"
        android:layout_width="match_parent"
        android:layout_height="@dimen/os_action_bar_height"
        android:layout_weight="1"
        android:layoutDirection="locale">
        <TextView
            android:textSize="@dimen/os_body_font"
            android:textColor="@color/os_text_quaternary_color"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/text_click"
            android:background="@drawable/os_search_round_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/os_auto_complete_textview_margin"
            android:layout_marginBottom="@dimen/os_auto_complete_textview_margin"
            android:maxLines="1"
            android:textDirection="locale"
            android:paddingEnd="@dimen/os_search_bar_text_padding_end"
            android:layout_marginStart="?attr/osSearchBarMargin"
            android:layout_marginEnd="?attr/osSearchBarMargin"/>
        <AutoCompleteTextView
            android:id="@+id/text_search"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:dropDownAnchor="@+id/relative_root"
            android:textDirection="locale"
            android:layout_marginStart="?attr/osSearchBarMargin"
            android:layout_marginEnd="?attr/osSearchBarMargin"
            style="@style/OsSearchTextStyle"/>
        <ImageView
            android:id="@+id/img_search_icon"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/os_ic_search_bar_hios"
            android:layout_centerVertical="true"
            android:layout_marginStart="?attr/osSearchBarIconMargin"/>
        <ImageView
            android:id="@+id/img_btn_back"
            android:background="@null"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="?attr/os_ic_back"
            android:layout_centerVertical="true"
            android:paddingStart="@dimen/os_icon_margin"
            android:paddingEnd="16dp"
            android:layout_marginEnd="10dp"
            android:paddingVertical="16dp"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/ll_del_custom_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerVertical="true"
            android:layoutDirection="locale"
            android:layout_marginEnd="26dp"
            android:layout_alignParentEnd="true">
            <ImageView
                android:id="@+id/img_delete_all"
                android:visibility="gone"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/os_ic_cancel"
                android:scaleType="centerInside"/>
            <ImageView
                android:id="@+id/img_custom_in_edittext"
                android:visibility="gone"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:scaleType="centerInside"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@+id/img_delete_all"/>
        </LinearLayout>
        <View
            android:background="@color/os_search_divider_color"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/os_search_divider_height"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/img_custom"
        android:visibility="gone"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/os_ic_search_bar_hios"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="22dp"/>
</LinearLayout>
