        android:state_enabled="false"
        android:state_checked="true"
        android:color="?attr/osColorControlActivated"
        android:alpha="@dimen/os_unselected_alpha_actionbar_text"/>
    <item
        android:state_enabled="false"
        android:state_checked="false"
